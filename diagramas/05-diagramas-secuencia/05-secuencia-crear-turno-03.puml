@startuml
title Diagrama de Secuencia - Crear Turno
' Nombre del escenario: Crear Turno - Flujo Principal
' Archivo: diagramas/03-escenarios-casos-de-uso/03-crear-turno-flujo-principal.md
' Objetivo: Representar la creación exitosa de un turno de control médico, involucrando secretaria, paciente y sistema, basado en responsabilidades de CRC (Secretaria gestiona turnos, Agenda registra disponibilidad, Turno asigna a paciente y médico).

actor Secretaria as victoria
actor Paciente as juan
participant "Agenda:agenda" as agenda
participant "Turno:turno" as turno

juan -> victoria: solicitarTurno(pacienteId, tipo)

victoria -> agenda: buscarPaciente(nombre_o_dni)
activate agenda

agenda --> victoria: pacienteEncontrado = id, nombre, dni
victoria -> agenda: seleccionarMedicoFechaHora(medicoId, fecha, hora, tipo)

agenda -> agenda: verificarDisponibilidad(medicoId, fecha, hora)
agenda --> victoria: disponibilidad = true

create turno
agenda -> turno: crearTurno(fecha, hora, pacienteId, medicoId, estado=confirmado)
activate turno

turno -> turno: cambiarEstado(confirmado)
turno -> agenda: registrarEnHistorial(turnoId, accion="crear", usuario=secretariaId)

agenda -> juan: enviarNotificacion(pacienteId, mensaje)

deactivate turno
deactivate agenda
@enduml