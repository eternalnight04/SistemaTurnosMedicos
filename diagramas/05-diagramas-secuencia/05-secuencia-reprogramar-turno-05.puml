@startuml
title Diagrama de Secuencia - Reprogramar Turno
' Nombre del escenario: Reprogramar Turno - Flujo Alterno
' Archivo: diagramas/03-escenarios-casos-de-uso/03-reprogramar-turno-flujo-alterno.md
' Objetivo: Representar la reprogramación de un turno por conflicto de horario, involucrando secretaria, paciente y sistema, basado en responsabilidades de CRC (Secretaria gestiona turnos, Turno reprograma, Agenda verifica disponibilidad).

actor Secretaria as victoria
actor Paciente as maria
participant "Agenda:agenda" as agenda
participant "Turno:turno" as turno

maria -> victoria: solicitarReprogramacion(pacienteId, turnoId, motivo)

victoria -> agenda: buscarTurno(turnoId)
activate agenda

agenda --> victoria: turnoEncontrado = id, fecha, hora, estado

victoria -> turno: solicitarReprogramacion(turnoId, nuevaFecha, nuevaHora)
activate turno

turno -> agenda: verificarDisponibilidad(nuevaFecha, nuevaHora)
agenda --> turno: disponibilidad = false
note over agenda, turno : Horario no disponible - ofrecer alternativas

agenda -> victoria: sugerirHorariosAlternativos(turnoId, alternativas)
victoria -> turno: seleccionarNuevoHorario(turnoId, horarioSeleccionado)

turno -> agenda: validarHorario(turnoId, horarioSeleccionado)
agenda --> turno: horarioValido = true
turno -> agenda: actualizarTurno(turnoId, nuevaFecha, nuevaHora)
turno -> turno: cambiarEstado(reprogramado)
turno -> agenda: registrarEnHistorial(turnoId, horarioAnterior, horarioNuevo, usuario)

agenda -> maria: enviarNotificacion(pacienteId, mensaje)

deactivate turno
deactivate agenda
@enduml