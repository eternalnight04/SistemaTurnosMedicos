@startuml Diagrama de Secuencia - Cancelar Turno
' Nombre del escenario: Cancelar Turno - Flujo Principal
' Archivo: diagramas/03-escenarios-casos-de-uso/03-cancelar-turno-flujo-principal.md
' Objetivo: Representar la cancelación de un turno a solicitud del paciente, involucrando secretaria, paciente y sistema, basado en responsabilidades de CRC (Secretaria gestiona turnos, Turno modifica estados, Agenda libera horarios).

actor Secretaria as victoria
actor Paciente as roberto
participant "Agenda:agenda" as agenda
participant "Turno:turno" as turno

roberto -> victoria: solicitarCancelacion(turnoId)

victoria -> agenda: buscarTurno(paciente, fecha)
activate agenda

agenda -> turno: obtenerTurno(turnoId)
agenda -> victoria: mostrarTurno(turnoId, estado)

victoria -> turno: cancelarTurno(motivo)
activate turno

turno -> agenda: liberarHorario(fecha, hora)
turno -> agenda: registrarEnHistorial(accion, usuario, motivo)

agenda -> roberto: enviarNotificacion(mensaje)

deactivate turno
deactivate agenda
@enduml