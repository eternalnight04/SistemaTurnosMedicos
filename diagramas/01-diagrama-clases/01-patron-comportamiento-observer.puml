@startuml Patrón Observer en Sistema de Turnos Médicos

' ==================== CLASES ABSTRACTAS Y INTERFACES ====================

interface iNotificacion {
    + actualizar(sujeto: Sujeto): void
}

abstract class Sujeto {
    # notificadores: List<iNotificacion>
    --
    + suscribir(notificacion: iNotificacion): void
    + desuscribir(notificacion: iNotificacion): void
    + notificar(): void
}

abstract class NotificacionMedio {
    --
    + enviarNotificacion(sujeto: Sujeto, sujeto2: Sujeto): void
    + actualizar(sujeto: Sujeto): void
}

' ==================== CLASES CONCRETAS ====================

class Turno {
    - id: String
    - fechaHora: DateTime
    - paciente: Paciente
    - medico: Medico
    - estado: TurnoEstado
    - sobreturno: boolean
    --
    + Turno(fechaHora, paciente, medico)
    + crearTurno(fechaHora, paciente, medico): void
    + cambiarEstado(nuevoEstado: TurnoEstado): void
    + reprogramar(nuevaFecha: DateTime): void
    + cancelar(motivo: String): void
}

class NotificacionEmail {
    - email: String
    --
    + NotificacionEmail(email: String)
    + enviarNotificacion(sujeto: Sujeto, sujeto2: Sujeto): void
    + actualizar(sujeto: Sujeto): void
}

class NotificacionWhatsapp {
    - telefono: String
    --
    + NotificacionWhatsapp(telefono: String)
    + enviarNotificacion(sujeto: Sujeto, sujeto2: Sujeto): void
    + actualizar(sujeto: Sujeto): void
}

class Auditoria {
    - eventos: List<String>
    --
    + guardarEvento(turno: Turno, cambio: String): void
    + actualizar(sujeto: Sujeto): void
}

class Paciente {
    - historiaClinica: String
    - telefono: String
    - email : String
    --
    + solicitarTurno(medico: Medico): void
    + confirmarTurno(turno: Turno): void
    + cancelarTurno(turno: Turno, motivo: String): void
}

class Medico {
    - especialidad: String
    - horarioDisponible: String
    --
    + consultarAgenda(fecha: DateTime): void
    + autorizarSobreturno(turno: Turno): void
}

' ==================== RELACIONES DE HERENCIA ====================

Sujeto <|-- Turno : hereda

' ==================== RELACIONES DE IMPLEMENTACIÓN ====================

iNotificacion <|.. NotificacionMedio : implementa
iNotificacion <|.. Auditoria : implementa

' ==================== RELACIONES DE COMPOSICIÓN Y AGREGACIÓN ====================

NotificacionMedio <|-- NotificacionEmail : hereda
NotificacionMedio <|-- NotificacionWhatsapp : hereda

Turno o-- Paciente : contiene
Turno o-- Medico : contiene

' ==================== RELACIONES DE ASOCIACIÓN ====================

Turno "0..*" -- "*" iNotificacion : observadores

Paciente "1" -- "*" Turno : solicita
Medico "1" -- "*" Turno : atiende

' ==================== ANOTACIONES ====================

note right of Sujeto
  Clase abstracta que encapsula
  el mecanismo de suscripción y notificación.
  Define el contrato para objetos observables.
end note

note right of iNotificacion
  Interfaz minimalista que define
  el contrato de actualización.
  Ejemplo de ISP (Interface Segregation Principle)
end note

note right of NotificacionMedio
  Clase abstracta que adapta
  la información del Turno a mensajes.
  Encapsula lógica común de transformación.
end note

note bottom of Turno
  Observable que notifica cambios de estado
  a todos sus observadores suscritos.
  Cumple con SRP al delegar notificaciones.
end note

note right of Paciente
  Observador que se suscribe a cambios
  en Turno para ser notificado vía
  Email o WhatsApp de nuevos estados.
end note

note right of Medico
  Observador que se suscribe a cambios
  en Turno para conocer estados del
  turno asignado.
end note

note right of Auditoria
  Observador que registra todos los
  cambios de estado del Turno para
  garantizar trazabilidad y auditoría.
end note

@enduml
