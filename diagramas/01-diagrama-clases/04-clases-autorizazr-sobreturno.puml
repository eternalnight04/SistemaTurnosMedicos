@startuml 04-clases-autorizar-sobreturno

title Diagrama de Clases - Autorizar Sobreturno

class Secretaria {
    -nombre: String

    +autorizarSobreturno(paciente: Paciente, medico: Medico, motivo: String): Sobreturno
}

class Paciente {
    -dni: String
    -nombre: String
}

class Medico {
    -matricula: String
    -nombre: String

    +tieneDisponibilidad(): boolean
}

class Sobreturno {
    -fechaHora: Date
    -motivo: String
    -estado: String
}

class Agenda {
    +verificarDisponibilidad(medico: Medico, fechaHora: Date): boolean
    +registrarSobreturno(sobreturno: Sobreturno): void
}

Secretaria --> Agenda : consulta
Secretaria --> Sobreturno : crea
Secretaria --> Paciente
Secretaria --> Medico

Agenda --> Medico
Sobreturno --> Paciente
Sobreturno --> Medico

@enduml