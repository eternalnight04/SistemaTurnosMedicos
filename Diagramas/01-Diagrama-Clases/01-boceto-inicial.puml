@startuml
' Diagrama de clases para el sistema de Turnos de Consultorio

package "Dominio de Turnos" {

  class Paciente {
    + pacienteId: UUID
    + nombre: String
    + apellido: String
    + documento: String
    + telefono: String
    + email: String

    + actualizarDatos(...): void
  }

  class Profesional {
    + profesionalId: UUID
    + nombre: String
    + apellido: String
    + especialidad: String

    + definirDisponibilidad(...): void
    + bloquearHorario(...): void
    + obtenerAgenda(rango: DateRange): Agenda
  }

  class Secretaria {
    + secretariaId: UUID
    + nombre: String
    + apellido: String
    + usuario: String
    + contraseña: String
    + rol: String

    + gestionarTurnos(): void
    + visualizarAgenda(): void
  }

  class TipoConsulta {
    + tipoId: UUID
    + nombre: String
    + duracionMinutos: int
    + descripcion: String
  }

  class Turno {
    + turnoId: UUID
    + fechaHoraInicio: DateTime
    + fechaHoraFin: DateTime
    + estado: TurnoEstado
    + motivoCancelacion: String?
    + esSobreturno: boolean
    + tipoConsulta: TipoConsulta

    + reprogramar(nuevoInicio: DateTime): void
    + cancelar(motivo: String): void
    + registrarLlegada(horaLlegada: DateTime): void
    + agregarAuditoria(entrada: Auditoria): void
  }

  class Agenda {
    + agendaId: UUID
    + profesional: Profesional
    + turnos: List<Turno>
    + bloqueos: List<BloqueoHorario>

    + obtenerTurnos(rango: DateRange): List<Turno>
    + buscarTurno(pacienteId: UUID): Turno?
    + validarDisponibilidad(inicio: DateTime, fin: DateTime): boolean
    + crearTurno(datos: TurnoDatos): Turno
    + reprogramarTurno(turnoId: UUID, nuevoInicio: DateTime): Turno
    + cancelarTurno(turnoId: UUID, motivo: String): Turno
    + registrarLlegada(turnoId: UUID, horaLlegada: DateTime): Turno
    + bloquearHorario(bloqueo: BloqueoHorario): void
    + generarSobreturno(turnoId: UUID): Turno
  }

  class BloqueoHorario {
    + bloqueoId: UUID
    + inicio: DateTime
    + fin: DateTime
    + motivo: String
    + tipo: BloqueoTipo
  }

  class Notificacion {
    + notificacionId: UUID
    + turnoId: UUID
    + destinatario: String
    + medio: NotificacionMedio
    + mensaje: String
    + enviada: boolean

    + enviar(): void
  }

  class Auditoria {
    + auditoriaId: UUID
    + turnoId: UUID
    + usuario: String
    + accion: String
    + fechaHora: DateTime
    + detalles: String
  }

  enum TurnoEstado {
    Programado
    Presente
    Cancelado
    Atendido
  }

  enum BloqueoTipo {
    Vacaciones
    Feriado
    Reunion
    Capacitación
  }

  enum NotificacionMedio {
    Email
    WhatsApp
  }

Paciente "1" -- "0..*" Turno : solicita >

Agenda --> Profesional : pertenece >
Turno "1" -- "1" Profesional : corresponde >

Secretaria ..> Agenda : utiliza >

Agenda "1" o-- "0..*" Turno : contiene >
Agenda "1" o-- "0..*" BloqueoHorario : gestiona >

Turno "1" -- "1" TipoConsulta : define >
Turno "1" -- "0..*" Auditoria : registra >

Turno "1" -- "1" Paciente

Notificacion "0..*" --> "1" Turno : pertenece >

@enduml
